#!/usr/bin/env python3

"""Encode videos to mp4 using named ffmpeg profiles."""

import argparse
import re
import secrets
import shutil
import subprocess
import sys
from pathlib import Path


PROFILES = {
    "whatsapp": {
        "description": "Baseline H.264 mp4 for WhatsApp sharing",
        "default_size": "x720",
        "h264_ffmpeg_args": [
            "-profile:v",
            "baseline",
        ],
        "ffmpeg_args": [
            "-pix_fmt",
            "yuv420p",
            "-movflags",
            "+faststart",
        ],
        "encoder_ffmpeg_args": {
            "libx264": [
                "-level",
                "3.0",
            ],
        },
    },
}

QUALITY_LEVELS = {
    "low": {
        "libx264": ["-preset", "veryfast", "-crf", "28"],
        "h264_nvenc": ["-preset", "p3", "-rc:v", "vbr", "-cq:v", "32", "-b:v", "0"],
        "h264_qsv": ["-preset", "fast", "-global_quality", "30"],
    },
    "medium": {
        "libx264": ["-preset", "medium", "-crf", "23"],
        "h264_nvenc": ["-preset", "p4", "-rc:v", "vbr", "-cq:v", "28", "-b:v", "0"],
        "h264_qsv": ["-preset", "medium", "-global_quality", "23"],
    },
    "high": {
        "libx264": ["-preset", "slow", "-crf", "20"],
        "h264_nvenc": ["-preset", "p6", "-rc:v", "vbr", "-cq:v", "22", "-b:v", "0"],
        "h264_qsv": ["-preset", "slow", "-global_quality", "20"],
    },
}


def parse_size(value):
    match = re.fullmatch(r"(?:(\d+)?)x(?:(\d+)?)", value)
    if not match:
        raise argparse.ArgumentTypeError(
            "size must look like WIDTHxHEIGHT, WIDTHx, or xHEIGHT"
        )

    width = int(match.group(1)) if match.group(1) else None
    height = int(match.group(2)) if match.group(2) else None

    if width is None and height is None:
        raise argparse.ArgumentTypeError("size must include width and/or height")

    if width == 0 or height == 0:
        raise argparse.ArgumentTypeError("size values must be greater than zero")

    return (width, height)


def build_scale_filter(size):
    if size is None:
        return None

    width, height = size

    if width and height:
        return (
            f"scale={width}:{height}:force_original_aspect_ratio=decrease:"
            "force_divisible_by=2"
        )

    if width:
        return f"scale={width}:-2"

    return f"scale=-2:{height}"


def default_output_path(src):
    return src.with_suffix(".mp4")


def unique_output_path(path):
    if not path.exists():
        return path

    while True:
        suffix = secrets.token_hex(4)[:7]
        candidate = path.with_name(f"{path.stem}_{suffix}{path.suffix}")
        if not candidate.exists():
            return candidate


def ffmpeg_encoders():
    try:
        result = subprocess.run(
            ["ffmpeg", "-hide_banner", "-encoders"],
            check=True,
            capture_output=True,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return ""

    return result.stdout


def probe_duration_seconds(path):
    try:
        result = subprocess.run(
            [
                "ffprobe",
                "-v",
                "error",
                "-show_entries",
                "format=duration",
                "-of",
                "default=noprint_wrappers=1:nokey=1",
                str(path),
            ],
            check=True,
            capture_output=True,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return None

    try:
        duration = float(result.stdout.strip())
    except ValueError:
        return None

    return duration if duration > 0 else None


def nvidia_encoder_available(encoders):
    if "h264_nvenc" not in encoders:
        return False

    if shutil.which("nvidia-smi") is None:
        return False

    try:
        subprocess.run(
            ["nvidia-smi"],
            check=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except (OSError, subprocess.CalledProcessError):
        return False

    return True


def intel_encoder_available(encoders):
    if "h264_qsv" not in encoders:
        return False

    for vendor_path in Path("/sys/class/drm").glob("renderD*/device/vendor"):
        try:
            vendor = vendor_path.read_text().strip().lower()
        except OSError:
            continue

        if vendor != "0x8086":
            continue

        render_node = Path("/dev/dri") / vendor_path.parents[1].name
        if render_node.exists():
            return True

    return False


def detect_video_encoder():
    encoders = ffmpeg_encoders()

    if nvidia_encoder_available(encoders):
        return ("h264_nvenc", "NVIDIA NVENC")

    if intel_encoder_available(encoders):
        return ("h264_qsv", "Intel Quick Sync")

    return ("libx264", None)


def print_progress_bar(progress):
    width = 40
    filled = min(width, max(0, round(progress * width)))
    bar = "#" * filled + "-" * (width - filled)
    percent = min(100, max(0, round(progress * 100)))
    print(f"\r[{bar}] {percent:3d}%", end="", flush=True)


def run_ffmpeg(command, src):
    duration = probe_duration_seconds(src)
    ffmpeg_command = [
        command[0],
        "-hide_banner",
        "-loglevel",
        "error",
        "-nostats",
        "-progress",
        "pipe:1",
        *command[1:],
    ]

    try:
        process = subprocess.Popen(
            ffmpeg_command,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except FileNotFoundError:
        print("ffmpeg is not installed")
        return 1

    last_progress = None
    progress_value = 0.0

    assert process.stdout is not None
    for line in process.stdout:
        key, _, value = line.strip().partition("=")

        if key == "out_time_ms" and duration:
            try:
                progress_value = min(float(value) / 1_000_000 / duration, 1.0)
            except ValueError:
                continue

            rounded_progress = round(progress_value, 3)
            if rounded_progress != last_progress:
                print_progress_bar(progress_value)
                last_progress = rounded_progress
        elif key == "progress" and value == "end":
            print_progress_bar(1.0)

    stderr_output = ""
    if process.stderr is not None:
        stderr_output = process.stderr.read().strip()

    return_code = process.wait()
    if last_progress is not None:
        print()

    if return_code != 0 and stderr_output:
        print(stderr_output, file=sys.stderr)

    return return_code


def parse_args():
    parser = argparse.ArgumentParser(
        description="Encode videos to mp4 using named ffmpeg profiles."
    )
    parser.add_argument("src", help="Source video file")
    parser.add_argument(
        "--profile",
        choices=sorted(PROFILES),
        default="whatsapp",
        help="Encoding profile to use",
    )
    parser.add_argument(
        "--size",
        type=parse_size,
        help="Resize output using WIDTHxHEIGHT, WIDTHx, or xHEIGHT",
    )
    parser.add_argument(
        "--quality",
        choices=["low", "medium", "high"],
        default="medium",
        help="Output quality level",
    )
    return parser.parse_args()


def build_command(src, dst, profile_name, size, quality):
    profile = PROFILES[profile_name]
    encoder, acceleration_name = detect_video_encoder()
    scale_filter = build_scale_filter(size)

    command = ["ffmpeg", "-i", str(src)]

    if scale_filter:
        command.extend(["-vf", scale_filter])

    command.extend(["-c:v", encoder])
    command.extend(profile.get("h264_ffmpeg_args", []))
    command.extend(profile.get("encoder_ffmpeg_args", {}).get(encoder, []))
    command.extend(QUALITY_LEVELS[quality].get(encoder, []))
    command.extend(profile["ffmpeg_args"])
    command.append(str(dst))

    return command, acceleration_name


def main():
    args = parse_args()
    src = Path(args.src)

    if not src.is_file():
        print("Source file does not exist")
        return 1

    size = args.size
    if size is None and PROFILES[args.profile]["default_size"]:
        size = parse_size(PROFILES[args.profile]["default_size"])

    dst = unique_output_path(default_output_path(src))
    command, acceleration_name = build_command(src, dst, args.profile, size, args.quality)

    print(f"Encoding to {dst}")
    print(f"Quality: {args.quality}")
    if acceleration_name:
        print(f"Using {acceleration_name} acceleration")

    return_code = run_ffmpeg(command, src)
    if return_code == 0:
        print(f"Output: {dst}")

    return return_code


if __name__ == "__main__":
    raise SystemExit(main())
