#!/usr/bin/env bash

cd ~/.config/hypr/monitors || exit 1

if [ -z "${1}" ]; then
  ls -- *.lua
else
  profile="${1}"
  if [[ "${profile}" != *.lua ]]; then
    profile="${profile}.lua"
  fi
  if [ -e "${profile}" ]; then
    ln -nfsv "${profile}" current.lua
    ls -- *.lua
  else
    echo "${profile} does not exist"
  fi
fi
