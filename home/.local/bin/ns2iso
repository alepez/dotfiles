#!/usr/bin/env python3
import argparse
from datetime import datetime, timezone

def ns_to_iso_full(nanoseconds):
    seconds, ns = divmod(nanoseconds, 1_000_000_000)
    dt = datetime.fromtimestamp(seconds, tz=timezone.utc)
    return dt.strftime('%Y-%m-%dT%H:%M:%S') + f'.{ns:09d}Z'

def main():
    parser = argparse.ArgumentParser(
        description="Convert nanosecond timestamps to ISO 8601 strings."
    )
    parser.add_argument(
        "nanoseconds",
        type=int,
        nargs="+",
        help="Timestamp(s) in nanoseconds since Unix epoch"
    )
    args = parser.parse_args()

    for ns in args.nanoseconds:
        print(ns_to_iso_full(ns))

if __name__ == "__main__":
    main()
